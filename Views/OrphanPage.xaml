<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui" 
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml" 
             x:Class="WEWE.Maui.Views.OrphanPage" 
             Title="Orphan">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="15">

            <Entry Placeholder="Full Name" Text="{Binding FullName}" />
            <Picker Title="Gender" ItemsSource="{Binding GenderOptions}" 
SelectedItem="{Binding Gender}" />
            <Entry Placeholder="Age" Keyboard="Numeric" Text="{Binding Age}" />

            <Picker Title="School Status" ItemsSource="{Binding SchoolStatusOptions}" 
SelectedItem="{Binding SchoolStatus}" />

            <Image Source="{Binding PhotoURL}" HeightRequest="150" WidthRequest="150" />
            <Button Text="Upload Photo" Command="{Binding UploadPhotoCommand}" />

            <Button Text="Save" Command="{Binding SaveOrphanCommand}" 
BackgroundColor="DodgerBlue" TextColor="White" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>