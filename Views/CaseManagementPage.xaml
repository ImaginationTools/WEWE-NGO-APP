<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui" 
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml" 
             x:Class="WEWE.Maui.Views.CaseManagementPage" 
             Title="Case Management">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="15">

            <Entry Placeholder="Subject" Text="{Binding Subject}" />
            <Editor Placeholder="Description" Text="{Binding Description}" HeightRequest="100" 
/>

            <Picker Title="Status" ItemsSource="{Binding StatusOptions}" 
SelectedItem="{Binding Status}" />
            <Picker Title="Priority" ItemsSource="{Binding PriorityOptions}" 
SelectedItem="{Binding Priority}" />

            <Button Text="Save Case" Command="{Binding SaveCaseCommand}" 
BackgroundColor="DodgerBlue" TextColor="White" />

            <CollectionView ItemsSource="{Binding Cases}">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Frame Padding="10" Margin="5" BorderColor="LightGray">
                            <VerticalStackLayout>
                                <Label Text="{Binding Subject}" FontAttributes="Bold" />
                                <Label Text="{Binding Status}" />
                                <Label Text="{Binding Priority}" />
                            </VerticalStackLayout>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage> 